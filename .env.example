# Copy to .env to override defaults. Every value here is optional --
# src/csrs/config.py holds the defaults and is the authoritative list.

# --- Ollama ---
# CSRS_OLLAMA_HOST=http://127.0.0.1:11434
# CSRS_DEFAULT_LLM=qwen2.5:1.5b
# CSRS_NUM_CTX=8192
# CSRS_KEEP_ALIVE=30m
# CSRS_TEMPERATURE=0.1

# The embedding model is mandated by the spec and by the task prefixes in
# embeddings.py. Changing it will silently degrade retrieval.
# CSRS_EMBED_MODEL=nomic-embed-text

# --- Paths ---
# CSRS_DOCS_DIR=docs
# CSRS_CHROMA_DIR=chroma_db

# --- Chunking ---
# CSRS_CHUNK_SIZE=400
# CSRS_CHUNK_OVERLAP=60

# --- Retrieval ---
# CSRS_TOP_K_DENSE=20
# CSRS_TOP_K_BM25=20
# CSRS_RRF_K=60
# CSRS_RERANK_TOP_N=5

# --- Generation ---
# Calibrated in T-4.2 against the golden set. Too high refuses valid questions.
# CSRS_REFUSAL_THRESHOLD=0.3
